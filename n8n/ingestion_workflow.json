      "id": "quality-schedule-node",
      "name": "Every 15 Minutes",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.1,
      "position": [250, 1050]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://elasticsearch:9200/sdoqap_quality_runs/_search",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "{\n  \"query\": {\n    \"range\": {\n      \"timestamp\": {\n        \"gte\": \"now-15m\"\n      }\n    }\n  }\n}",
        "options": {}
      },
      "id": "fetch-quality-runs-node",
      "name": "Fetch Recent Quality Runs",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [450, 1050],
      "retryOnFail": true,
      "maxTries": 3,
      "delayBetweenRetries": 5000
    },
    {
      "parameters": {
        "jsCode": "const hits = $json.hits?.hits || [];\nreturn hits\n  .map(hit => hit._source)\n  .filter(run => run.quarantined_records > 0 || (run.quality_score < (run.effective_quality_threshold || 90.0)))\n  .map(run => ({\n    json: {\n      title: `[Data Quality Alert] Table: ${run.table_name}`,\n      message: `Quality Score dropped to ${run.quality_score.toFixed(2)}% (Threshold: ${run.effective_quality_threshold || 90.0}%). Quarantined records: ${run.quarantined_records} out of ${run.total_records}. Run ID: ${run.run_id}`,\n      severity: run.quarantined_records > 50 ? 'critical' : 'warning'\n    }\n  }));"
      },
      "id": "filter-low-quality-runs-node",
      "name": "Filter Low Quality Runs",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [650, 1050]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://api:8000/api/v1/system/alert",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"title\": $json.title,\n  \"message\": $json.message,\n  \"severity\": $json.severity\n}",
        "options": {}
      },
      "id": "route-quality-alert-node",
      "name": "Route Quality Alert",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [850, 1050]
    }
