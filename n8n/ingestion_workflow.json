      "parameters": {
        "jsCode": "const binaryDataBuffer = await this.helpers.getBinaryDataBuffer(0, 'data');\nconst textString = Buffer.from(binaryDataBuffer).toString('utf-8');\nreturn { json: { csv: textString } };"
