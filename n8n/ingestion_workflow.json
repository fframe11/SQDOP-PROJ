      "typeVersion": 1.1,
      "position": [250, 900]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://elasticsearch:9200/sdoqap_upstream_remediations/_search",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "{\n  \"query\": {\n    \"range\": {\n      \"timestamp\": {\n        \"gte\": \"now-1h\"\n      }\n    }\n  }\n}",
        "options": {}
      },
      "id": "fetch-remediations-node",
      "name": "Fetch Recent Remediations",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [450, 900],
      "retryOnFail": true,
      "maxTries": 3,
      "delayBetweenRetries": 5000
    },
    {
      "parameters": {
        "jsCode": "const hits = $json.hits?.hits || [];\nreturn hits.map(hit => ({\n  json: {\n    title: `[Remediation Ticket] ${hit._source.table_name}`,\n    message: `A quality anomaly occurred. Remediation Action required: ${hit._source.remediation_action} (Target: ${hit._source.target_system})`,\n    severity: hit._source.severity || 'warning'\n  }\n}));"
      },
      "id": "parse-remediations-node",
      "name": "Parse Remediation Tickets",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [650, 900]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://api:8000/api/v1/system/alert",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"title\": $json.title,\n  \"message\": $json.message,\n  \"severity\": $json.severity\n}",
        "options": {}
      },
      "id": "route-remediation-alert-node",
      "name": "Route Remediation Alert",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [850, 900]
    },
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "minutes",
              "minutesInterval": 15
